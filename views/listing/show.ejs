<%- layout("/layouts/boilerplat") %>

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10 col-sm-12">
      <h3 class="mb-3 text-center"><%= List.title %></h3>

      <div class="card shadow-sm">
        <img
          src="<%= List.image.url %>"
          class="card-img-top show-img"
          alt="listing-image"
        />

        <div class="card-body">
          <p class="card-text">
            <p> Owner : <b><%= List.owner.username%></b> </p>
            <p><%= List.description %></p>

            <b>&#8377;<%= List.price.toLocaleString("en-IN") %></b><br />
            <%= List.location %>, <%= List.country %>
          </%p>
          <div class="d-flex gap-2 mt-3">
            <a
              href="/listings/<%= List._id %>/edit"
              class="btn btn-outline-dark"
            >
              Edit
            </a>

            <form
              method="post"
              action="/listings/<%= List._id %>?_method=DELETE"
            >
              <button class="btn btn-danger">Delete</button>
            </form>
          </div>
        
          <hr />
          <div>
            <h4 class="offset-5"><B>Add Reviews...</B></h4>
            <form
              method="post"
              action="/listings/<%=List._id%>"
              class="needs-validation"
              novalidate
            >
              <div class="review-rating mb-3">
                <div class="review-rating-row">
                  <span class="review-rating-label">Rating</span>
                  <div class="star-rating" aria-label="Choose rating">
                    <input
                      type="radio"
                      id="star5"
                      name="reviews[rating]"
                      value="5"
                      required
                    />
                    <label for="star5" title="5 stars">&#9733;</label>

                    <input
                      type="radio"
                      id="star4"
                      name="reviews[rating]"
                      value="4"
                    />
                    <label for="star4" title="4 stars">&#9733;</label>

                    <input
                      type="radio"
                      id="star3"
                      name="reviews[rating]"
                      value="3"
                    />
                    <label for="star3" title="3 stars">&#9733;</label>

                    <input
                      type="radio"
                      id="star2"
                      name="reviews[rating]"
                      value="2"
                    />
                    <label for="star2" title="2 stars">&#9733;</label>

                    <input
                      type="radio"
                      id="star1"
                      name="reviews[rating]"
                      value="1"
                      checked
                    />
                    <label for="star1" title="1 star">&#9733;</label>
                  </div>
                </div>
                <div class="review-score">Pick a star to rate this stay.</div>
              </div>
              <div>
                <!--  this name = [Comments] is also match to the models Commants -->
                <textarea
                  id="Commants"
                  name="reviews[Comment]"
                  cols="30"
                  rows="4"
                  class="form-control"
                  required
                ></textarea>
                <div class="invalid-feedback">Please enter your Commants.</div>
                <label for="Commants" class="form-label">Commants</label>
              </div>
              <button class="btn btn-danger">Submit</button>
            </form>
          </div>
          <hr />
          <br />
          <p><b>All Reviews</b></p>
           <div class="row">
            <% for(review of List.reviews) { %>
              <div class="card review-card col-5 ms-3 mb-3">
                  <div class="card-body">
                   <% if(review.author){ %>
                    <h5 class="card-title">
                      <%= review.author.username %>
                    </h5>
                   <% } %>
                      <p class="card-text"><%= review.Comment %></p>
                      <p class="card-text review-stars">
                        <span class="review-stars-icons" aria-hidden="true">
                          <%= "★".repeat(review.rating) %><%= "☆".repeat(5 - review.rating) %>
                        </span>
                      </p>
                      
                  </div>
                  <form class="review-delete" method="POST" action="/listings/<%=List._id%>/<%=review._id%>/delete/?_method=DELETE"> 
                       <button type="submit" class="btn">
                        <span class="material-symbols-outlined"> delete_forever  </span>
                      </button>
                  </form>
              </div>
            <% } %>
         </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/JS/formValidate.js"></script>
